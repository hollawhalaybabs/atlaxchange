<odoo>
    <record id="view_create_transaction_fee_wizard_form" model="ir.ui.view">
        <field name="name">create.transaction.fee.wizard.form</field>
        <field name="model">create.transaction.fee.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Transaction Fee">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="business_id"/>
                    </group>
                    <group>
                        <field name="currency_code"/>
                        <field name="transfer_direction"/>
                    </group>
                    <group>
                        <field name="fee"/>
                        <field name="type"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_fee" type="object" string="Create" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>