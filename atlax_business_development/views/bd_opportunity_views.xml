<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action -->
    <record id="action_atlax_bd_opportunity" model="ir.actions.act_window">
        <field name="name">Business Development</field>
        <field name="res_model">atlax.bd.opportunity</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create onboarding record
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_atlax_bd_root" name="Business Development"
              parent="atlaxchange_app.atlaxchange_menu" sequence="20"
              groups="base.group_system,atlaxchange_app.group_business_dev_officer,atlaxchange_app.group_business_dev_manager,atlaxchange_app.group_compliance_officer,atlaxchange_app.group_compliance_manager,atlaxchange_app.group_coo,atlaxchange_app.group_ceo"/>
    <menuitem id="menu_atlax_bd_onboarding" name="Onboarding"
              parent="menu_atlax_bd_root" action="action_atlax_bd_opportunity" sequence="1"
              groups="base.group_system,atlaxchange_app.group_business_dev_officer,atlaxchange_app.group_business_dev_manager,atlaxchange_app.group_compliance_officer,atlaxchange_app.group_compliance_manager,atlaxchange_app.group_coo,atlaxchange_app.group_ceo"/>

    <!-- Tree View -->
    <record id="view_atlax_bd_opportunity_tree" model="ir.ui.view">
        <field name="name">atlax.bd.opportunity.tree</field>
        <field name="model">atlax.bd.opportunity</field>
        <field name="arch" type="xml">
            <tree string="Onboarding List">
                <field name="name"/>
                <field name="type"/>
                <field name="vendor_type"/>
                <field name="email"/>
                <field name="settlement_currency_id"/>
                <field name="assign_staff_id"/>
                <field name="state"/>
                <field name="datetime"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_atlax_bd_opportunity_form" model="ir.ui.view">
        <field name="name">atlax.bd.opportunity.form</field>
        <field name="model">atlax.bd.opportunity</field>
        <field name="arch" type="xml">
            <form string="Onboarding List">
                <header>
                    <field name="state" widget="statusbar"
                       statusbar_visible="draft,proposal_sent,nda_signoff,kyb_review,done"/>
                    
                    <!-- State transition buttons -->
                    <button name="action_set_draft" type="object" string="Set Draft" class="btn-secondary"
                        confirm="Are you sure you want to set this record back to Draft?"
                        attrs="{'invisible': [('state', '=', 'draft')]}"/>
                    <button name="action_set_initial_discussion" type="object" string="Initial Discussion" class="btn-secondary"
                        confirm="Are you sure you want to move this record to Initial Discussion?"
                        attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_set_proposal_sent" type="object" string="Proposal Sent" class="btn-secondary"
                        confirm="Are you sure you want to move this record to Proposal Sent?"
                        attrs="{'invisible': [('state', '!=', 'initial_discussion')]}"/>
                    <button name="action_set_nda_signoff" type="object" string="NDA Signoff" class="btn-secondary"
                        confirm="Are you sure you want to move this record to NDA Signoff?"
                        attrs="{'invisible': [('state', '!=', 'proposal_sent')]}"/>
                    <button name="action_set_commercial_discussion" type="object" string="Commercial" class="btn-secondary"
                        confirm="Are you sure you want to move this record to Commercial Discussion?"
                        attrs="{'invisible': [('state', '!=', 'nda_signoff')]}"/>
                    <button name="action_set_kyb_review" type="object" string="KYB Review" class="btn-secondary"
                        confirm="Are you sure you want to move this record to KYB Review?"
                        attrs="{'invisible': [('state', '!=', 'commercial_discussion')]}"/>
                    <button name="action_set_contract_signoff" type="object" string="Contract Signoff" class="btn-secondary"
                        confirm="Are you sure you want to move this record to Contract Signoff?"
                        attrs="{'invisible': [('state', '!=', 'kyb_review')]}"/>
                    <button name="action_set_integration" type="object" string="Integration" class="btn-secondary"
                        confirm="Are you sure you want to move this record to Integration?"
                        attrs="{'invisible': [('state', '!=', 'contract_signoff')]}"/>
                    <button name="action_set_onhold" type="object" string="On Hold" class="btn-secondary"
                        confirm="Are you sure you want to put this record On Hold?"
                        attrs="{'invisible': [('state', 'not in', ['proposal_sent', 'initial_discussion', 'nda_signoff', 'commercial_discussion', 'kyb_review', 'contract_signoff', 'integration'])]}"/>
                    <button name="action_set_done" type="object" string="Done" class="btn-success"
                        confirm="Are you sure you want to mark this record as Done?"
                        attrs="{'invisible': [('state', '!=', 'integration')]}"/>

                    <!-- Email buttons -->
                        <button name="action_send_reminder_email" type="object" string="Send Reminder" class="btn-danger"
                            confirm="Send a reminder email to this contact?"/>
                        <button name="action_send_proposal_email" type="object" string="Send Proposal" class="btn-primary"
                            confirm="Send the proposal email to this contact?"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                        <button name="action_send_nda_email" type="object" string="Send NDA" class="btn-secondary"
                            confirm="Send the NDA email to this contact?"
                            attrs="{'invisible': [('state', '!=', 'proposal_sent')]}"/>
                </header>

                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button
                            type="object"
                            name="action_open_helpdesk_tickets"
                            class="oe_stat_button"
                            icon="fa-life-ring">
                            <field name="helpdesk_ticket_count" widget="statinfo" string="Helpdesk"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Company Name"/> 
                        </h1> 
                    </div>
                    <group>
                        <group>
                            <field name="assign_staff_id"/>
                            <field name="type"/>
                            <field name="vendor_type" attrs="{'required': [('type', '=', 'vendor')], 'invisible': [('type', '!=', 'vendor')]}"/>
                            <field name="email"/>
                            <field name="website" widget="url"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>  
                        </group>
                        
                        <group string="Documents">
                            <field name="datetime" readonly="1"/>
                            <field name="proposal_document" filename="proposal_filename"/>
                            <field name="nda_document" filename="nda_filename"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Commercial">
                            <group>
                                <field name="settlement_currency_id" attrs="{'required': [('state', '=', 'commercial_discussion')]}"/>
                                <field name="funding_type" attrs="{'required': [('state', '=', 'commercial_discussion')]}"/>
                            </group>
                            <group string="Fees">
                                <field name="fee_ids">
                                    <tree editable="bottom">
                                        <field name="source_currency_id"/>
                                        <field name="target_currency_id"/>
                                        <field name="corridor" readonly="1"/>
                                        <field name="fee_amount"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                        <page string="KYB">
                            <group>
                                <field name="kyb_status" attrs="{'required': [('state', '=', 'kyb_review')]}"/>
                            </group>
                        </page>
                        <page string="Remarks">
                            <group>
                                <field name="remark" colspan="4"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <!-- Right-side Followers/Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
