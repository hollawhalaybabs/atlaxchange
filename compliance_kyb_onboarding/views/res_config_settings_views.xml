<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
  <record id="res_config_settings_view_form_kyb" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.kyb</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[hasclass('settings')]" position="inside">
        <div class="app_settings_block" data-string="KYB Onboarding" string="KYB Onboarding" data-key="kyb_onboarding">
          <h2>KYB Onboarding</h2>
          <div class="row mt16 o_settings_container">
            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane">
                <field name="kyb_show_risk_section_public"/>
              </div>
              <div class="o_setting_right_pane">
                <label for="kyb_show_risk_section_public"/>
                <div class="text-muted">
                  If enabled, customers will see the Risk-based section on the public onboarding page.
                </div>
              </div>
            </div>
          </div>
        </div>
      </xpath>
    </field>
  </record>
  </data>
</odoo>
