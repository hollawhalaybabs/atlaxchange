<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Allocate Transactions Wizard: Form -->
    <record id="view_allocate_transactions_wizard_form" model="ir.ui.view">
        <field name="name">allocate.transactions.wizard.form</field>
        <field name="model">allocate.transactions.wizard</field>
        <field name="arch" type="xml">
            <form string="Allocate Transactions" create="false" edit="false">
                <group>
                    <group>
                        <field name="stock_id" options="{'no_create': True}"/>
                        <field name="batch_id" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="allocation_date"/>
                        <field name="allocation_mode"/>
                    </group>
                </group>

                <field name="line_ids" nolabel="1" context="{'default_wizard_id': active_id}">
                    <tree editable="bottom" create="false" delete="true">
                        <field name="transaction_reference" readonly="1"/>
                        <field name="customer_id" readonly="1"/>
                        <field name="transaction_date" readonly="1"/>
                        <field name="unallocated_amount" readonly="1"/>
                        <field name="allocate_amount"/>
                    </tree>
                </field>

                <footer>
                    <button name="action_allocate" type="object" string="Allocate" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Allocate Transactions Wizard: Action -->
    <record id="action_allocate_transactions_wizard" model="ir.actions.act_window">
        <field name="name">Allocate Transactions</field>
        <field name="res_model">allocate.transactions.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_allocate_transactions_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_stock_id': active_id}</field>
    </record>
</odoo>
