<odoo>
    <record id="view_update_transaction_fee_v2_wizard_form" model="ir.ui.view">
        <field name="name">update.transaction.fee.v2.wizard.form</field>
        <field name="model">update.transaction.fee.v2.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Transaction Fee (v2)">
                <group>
                    <group>
                        <field name="fee_line_id"/>
                        <field name="fee_id"/>
                        <field name="business_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="source_currency_id" readonly="1"/>
                        <field name="target_currency_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="transfer_direction"/>
                        <field name="payment_method"/>
                        <field name="payment_method_type"/>
                        <field name="amount_type"/>
                    </group>
                    <group>
                        <field name="max_fee"/>
                        <field name="fixed_fee"/>
                        <field name="percentage_fee"/>
                        <field name="percentage_cap"/>
                    </group>
                </group>
                <footer>
                    <button name="action_update_fee_v2" type="object" string="Update" class="btn-primary"
                            confirm="Are you sure you want to continue?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
