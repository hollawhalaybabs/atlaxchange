<odoo>
    <record id="view_create_transaction_fee_v2_wizard_form" model="ir.ui.view">
        <field name="name">create.transaction.fee.v2.wizard.form</field>
        <field name="model">create.transaction.fee.v2.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Transaction Fee (v2)">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="business_id"/>
                    </group>
                    <group>
                        <field name="source_currency_id"/>
                        <field name="target_currency_id"/>
                    </group>
                    <group>
                        <field name="transfer_direction"/>
                        <field name="payment_method"/>
                        <field name="payment_method_type"/>
                        <field name="amount_type"/>
                    </group>
                    <group>
                        <field name="max_fee"/>
                        <field name="fixed_fee"/>
                        <field name="percentage_fee"/>
                        <field name="percentage_cap"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_fee_v2" type="object" string="Create" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
