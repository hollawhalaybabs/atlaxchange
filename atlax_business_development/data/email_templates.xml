<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- INTERNAL: Reminder Email (no external recipient) -->
    <record id="email_template_bd_reminder" model="mail.template">
        <field name="name">BD Reminder (Internal)</field>
        <field name="model_id" ref="model_atlax_bd_opportunity"/>
        <field name="subject">Reminder: Follow-up needed for ${object.name or 'BD Opportunity'}</field>
        <field name="email_from">${(user.email_formatted or '')|safe}</field>

        <!-- IMPORTANT: keep template recipients empty; we prefill recipients in the composer -->
        <field name="email_to"></field>
        <field name="email_cc"></field>
        <field name="partner_to"></field>

        <field name="body_html" type="html">
            <div>
                <p>Hello,</p>
                <p>
                    This is an internal reminder to follow up on the BD opportunity:
                    <strong>${object.name or ''}</strong>
                    <t t-if="object.trade_name"> (${object.trade_name})</t>
                </p>
                <ul>
                    <li><strong>Type:</strong> ${dict(object._fields['type'].selection).get(object.type) or object.type or ''}</li>
                    <li><strong>Status:</strong> ${dict(object._fields['state'].selection).get(object.state) or object.state or ''}</li>
                    <li><strong>Assigned Staff:</strong> ${object.assign_staff_id.name or ''}</li>
                </ul>
                <p>Thanks,<br/>${user.name}</p>
            </div>
        </field>
    </record>

