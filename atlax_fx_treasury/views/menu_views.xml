              groups="atlax_fx_treasury.group_treasury_user,atlax_fx_treasury.group_treasury_manager"/>

    <!-- Existing FX rate computation menu kept for backward compatibility -->
    <menuitem id="menu_fx_rates" name="FX Rate Computations" parent="menu_trade_treasury_root"
              action="atlax_fx_treasury.action_fx_rate_window" sequence="90"
              groups="atlax_fx_treasury.group_fx_officer,atlax_fx_treasury.group_fx_manager,base.group_system"/>
