<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="atlax_balance_sheet_report" model="account.report">
        <field name="name">Atlax Balance Sheet</field>
        <field name="filter_date_range" eval="False"/>
        <field name="filter_show_draft" eval="True"/>
        <field name="filter_journals" eval="True"/>
        <field name="filter_multi_company">selector</field>
        <field name="default_opening_date_filter">today</field>
        <field name="search_template">atlax_wallet_accounting_sync.search_template_atlax_wallet_report</field>
        <field name="custom_handler_model_id" ref="model_atlax_balance_sheet_report_handler"/>
        <field name="atlax_custom_report" eval="True"/>
        <field name="atlax_wallet_scope" eval="True"/>
        <field name="atlax_currency_filter" eval="True"/>
        <field name="column_ids">
            <record id="atlax_balance_sheet_report_balance" model="account.report.column">
                <field name="name">Balance</field>
                <field name="expression_label">balance</field>
                <field name="figure_type">monetary</field>
            </record>
        </field>
    </record>

    <record id="atlax_profit_and_loss_report" model="account.report">
        <field name="name">Atlax Profit and Loss</field>
