<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Root menu (update existing id from older versions of this addon) -->
    <menuitem id="menu_trade_treasury_root" name="Treasury FX" sequence="8"
              parent="atlaxchange_app.atlaxchange_menu"
              groups="atlax_fx_treasury.group_treasury_user,atlax_fx_treasury.group_treasury_manager,atlax_fx_treasury.group_fx_officer,atlax_fx_treasury.group_fx_manager"/>

    <!-- Phase 1 Treasury Allocation menus -->
    <menuitem id="menu_treasury_daily_batches" name="Dashboard / Daily Batches" parent="menu_trade_treasury_root"
